# Django core
DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.habluj.sk
DJANGO_CORS_ALLOWED_ORIGINS=https://habluj.vercel.app,https://habluj.sk
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.habluj.sk,https://habluj.vercel.app

# MailerLite CRM sync + notification email
MAILERLITE_API_KEY=replace-with-mailerlite-api-key
MAILERLITE_LEAD_GROUP_ID=
MAILERLITE_SENDER_EMAIL=notifications@habluj.sk
MAILERLITE_SENDER_NAME=Habluj
MAILERLITE_NOTIFICATION_TO=habluj.sk@gmail.com
BOOKING_PUBLIC_URL=https://habluj.setmore.com/
SERVICES_PUBLIC_URL=https://habluj.sk/tutoring-services

# Optional absolute base URL used inside notification email links
DJANGO_ADMIN_BASE_URL=https://api.habluj.sk

# Optional: SMTP channel for lead notifications/results with MailerLite setup
# Recommended backend for real delivery:
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
DJANGO_EMAIL_TIMEOUT=10
DJANGO_DEFAULT_FROM_EMAIL=no-reply@habluj.local

# Optional external integrations for lead sync/notifications.
# Default should remain False for a self-contained local setup.
LEAD_EXTERNAL_INTEGRATIONS_ENABLED=False

# GoPay payments (MVP)
GOPAY_CLIENT_ID=
GOPAY_CLIENT_SECRET=
GOPAY_GOID=
GOPAY_WEBHOOK_SECRET=
GOPAY_CHECKOUT_BASE_URL=https://gate.gopay.cz

# Booking payment settings
# Fixed conversion for MVP: 1 EUR = 25 CZK
BOOKING_EUR_TO_CZK_RATE=25
# Pending payment TTL in minutes
BOOKING_PAYMENT_TTL_MINUTES=15

# Agenda core rules
BOOKING_CLASS_MINUTES=60
BOOKING_LEAD_TIME_HOURS=12
BOOKING_CHANGE_WINDOW_HOURS=24
BOOKING_DEFAULT_BUFFER_MINUTES=10
BOOKING_TEACHER_TIMEZONE=Europe/Madrid

# Google Calendar integration (optional but recommended)
GOOGLE_CALENDAR_ID=
# Full JSON in one line
GOOGLE_SERVICE_ACCOUNT_JSON=
