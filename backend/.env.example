# Django core
DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.habluj.sk
DJANGO_CORS_ALLOWED_ORIGINS=https://habluj.vercel.app,https://habluj.sk
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.habluj.sk,https://habluj.vercel.app

# Brevo CRM sync + notification email
BREVO_API_KEY=replace-with-brevo-api-key
BREVO_LEAD_LIST_ID=
BREVO_SENDER_EMAIL=notifications@habluj.sk
BREVO_SENDER_NAME=Habluj
BREVO_NOTIFICATION_TO=habluj.sk@gmail.com

# Optional absolute base URL used inside notification email links
DJANGO_ADMIN_BASE_URL=https://api.habluj.sk

# Optional: SMTP fallback for lead notifications when Brevo is unavailable
# Recommended backend for real delivery:
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
DJANGO_EMAIL_TIMEOUT=10
DJANGO_DEFAULT_FROM_EMAIL=no-reply@habluj.local

# Optional external integrations for lead sync/notifications.
# Default should remain False for a self-contained local setup.
LEAD_EXTERNAL_INTEGRATIONS_ENABLED=False
