# Frontend (Vite)
# URL publica del backend Django que expone /api/
# Development: http://localhost:8000
# Production: https://api.habluj.sk
VITE_API_BASE_URL=https://api.habluj.sk

# Google Calendar (dashboard de Ester)
# Opcion recomendada: solo Calendar ID (ej: tu_email@gmail.com)
VITE_GOOGLE_CALENDAR_ID=
VITE_GOOGLE_CALENDAR_TIMEZONE=Europe/Madrid
VITE_GOOGLE_CALENDAR_LOCALE=es
# Opcional: usar URL completa en vez del ID
VITE_GOOGLE_CALENDAR_EMBED_URL=
VITE_GOOGLE_CALENDAR_PUBLIC_URL=
