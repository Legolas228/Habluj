{
  "version": 2,
  "outputDirectory": "build",
  "redirects": [
    {
      "source": "/",
      "destination": "/sk",
      "permanent": true
    },
    {
      "source": "/homepage",
      "destination": "/sk",
      "permanent": true
    },
    {
      "source": "/contact",
      "destination": "/sk/contact",
      "permanent": true
    },
    {
      "source": "/tutoring-services",
      "destination": "/sk/tutoring-services",
      "permanent": true
    },
    {
      "source": "/about-the-teacher",
      "destination": "/sk/about-the-teacher",
      "permanent": true
    },
    {
      "source": "/booking-system",
      "destination": "/sk/booking-system",
      "permanent": true
    },
    {
      "source": "/privacy-policy",
      "destination": "/sk/privacy-policy",
      "permanent": true
    },
    {
      "source": "/terms-and-conditions",
      "destination": "/sk/terms-and-conditions",
      "permanent": true
    },
    {
      "source": "/cookies-policy",
      "destination": "/sk/cookies-policy",
      "permanent": true
    },
    {
      "source": "/login",
      "destination": "/sk/login",
      "permanent": true
    },
    {
      "source": "/signup",
      "destination": "/sk/signup",
      "permanent": true
    },
    {
      "source": "/student-dashboard",
      "destination": "/sk/student-dashboard",
      "permanent": true
    },
    {
      "source": "/ester-dashboard",
      "destination": "/sk/ester-dashboard",
      "permanent": true
    },
    {
      "source": "/level-questionnaire",
      "destination": "/sk/level-questionnaire",
      "permanent": true
    },
    {
      "source": "/intensive-courses",
      "destination": "/sk/intensive-courses",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; form-action 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https:; frame-src 'self' https://habluj.setmore.com https://*.setmore.com https://docs.google.com; child-src 'self' https://habluj.setmore.com https://*.setmore.com https://docs.google.com; manifest-src 'self'; upgrade-insecure-requests"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        }
      ]
    }
  ]
}
